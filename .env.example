APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=herohub
DB_USERNAME=root
DB_PASSWORD=

# Digital membership card title (customer portal + PDF)
# HERO_CARD_COMPANY_NAME="HERO Client Rescue S.A."

# Optional: link a demo membership to this user if they have none (with BindDemoMembershipSeeder)
# HERO_BIND_MEMBERSHIP_EMAIL=you@example.com

# Zoho Billing → portal: POST JSON to {APP_URL}/api/v1/webhooks/zoho/subscription
# Header: X-Hero-Zoho-Webhook-Secret: <same value>   (or Authorization: Bearer <same value>)
# ZOHO_WEBHOOK_SECRET=use-a-long-random-string
# ZOHO_WEBHOOK_AUTO_CREATE_USERS=false
# ZOHO_WEBHOOK_NEW_MEMBERSHIP_MAIL=true

# Optional: Zoho Billing customer portal URL (shown when changing plan / checkout)
# ZOHO_CUSTOMER_PORTAL_URL=https://billing.zoho.com/portal/yourorg

# Zoho CRM: one zapikey per Deluge function (keys differ per function in Zoho)
# ZOHO_CRM_ZAPIKEY_CREATE_SUBSCRIPTION=
# ZOHO_CRM_ZAPIKEY_UPDATE_SUBSCRIPTION=
# ZOHO_CRM_ZAPIKEY_CANCEL_SUBSCRIPTION=
# ZOHO_CRM_ZAPIKEY_GET_CURRENT_SUBSCRIPTION_STATUS=
# ZOHO_CRM_ZAPIKEY_GET_SUBSCRIPTION_RELATED_INVOICES=
# ZOHO_CRM_ZAPIKEY_GET_SUBSCRIPTION_RELATED_PAYMENTS=

# Stripe (membership plan change — Checkout). When STRIPE_SECRET is set, upgrade/downgrade uses Stripe before Zoho iframe checkout.
# STRIPE_SECRET=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
# Database-backed sessions (requires `sessions` table — php artisan migrate).
SESSION_DRIVER=database
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=phpmail
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="HERO Client Rescue S.A."
# Optional 5th parameter to PHP mail(), e.g. envelope sender: -fnotifications@yourdomain.com
MAIL_PHPMAIL_PARAMS=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
